@model SistemaAccesoWeb.Models.LoginViewModel

@{
    ViewData["Title"] = "Gestión de usuarios";
}

<div class="gestion-page">
    <partial name="_Header" />

    <main class="gestion-main">
        <div class="gestion-background">
            <div class="gestion-bg-art"></div>

            <section class="login-panel">
                <div class="document-tabs">
                    <button type="button" class="doc-tab active">DNI</button>
                    <button type="button" class="doc-tab">CE</button>
                </div>

                <form asp-action="GestionUsuarios" asp-controller="Home" method="post" class="login-form">
                    <div class="form-group">
                        <label asp-for="NumeroDocumento">Usuario</label>
                        <div class="input-icon-wrapper">
                            <img src="~/images/icon-user.svg" alt="Usuario" class="input-icon" />
                            <input asp-for="NumeroDocumento" placeholder="Ingresar usuario" />
                        </div>
                        <span asp-validation-for="NumeroDocumento" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Contrasena">Contraseña</label>
                        <div class="input-icon-wrapper password-wrapper">
                            <img src="~/images/icon-lock.svg" alt="Contraseña" class="input-icon" />
                            <input asp-for="Contrasena" type="password" placeholder="Ingresar contraseña" />
                            <button type="button" class="password-toggle" aria-label="Mostrar contraseña">
                                <img src="~/images/icon-eye.svg" alt="Ver contraseña" class="password-eye-icon" />
                            </button>
                        </div>
                        <span asp-validation-for="Contrasena" class="text-danger"></span>
                    </div>

                    @if (!string.IsNullOrEmpty(Model?.MensajeError))
                    {
                        <div class="text-danger login-error-message">
                            @Model.MensajeError
                        </div>
                    }

                    <a href="#" class="forgot-password">¿Olvidó su contraseña?</a>

                    <button type="submit" class="login-button">Ingresar</button>
                </form>
            </section>

            <section class="support-box">
                <div class="support-icon">
                    <img src="~/images/icon-support.svg" alt="Soporte" class="support-icon-img" />
                </div>
                <p>
                    ¿Necesita ayuda?,
                    <a href="#">contacte con el área de soporte</a>
                </p>
            </section>
        </div>
    </main>

    <partial name="_Footer" />
</div>