@{
    ViewData["Title"] = "Activación de cuenta";
}

<div class="activation-page">
    <div class="top-bar">
        <div class="logo-container">
            <img src="~/images/ceplan-logo.svg" alt="Logo CEPLAN" class="header-logo" />
        </div>

        <div class="help-icon">
            <img src="~/images/help-icon.svg" alt="Ayuda" class="help-icon-img" />
        </div>
    </div>

    <main class="activation-wrapper">
        <div class="activation-card">
            <div class="icon-circle">
                <img src="~/images/rocket-icon.svg" alt="Activación exitosa" class="rocket-icon-img" />
            </div>

            <h2 class="activation-title">¡Bienvenida, July!</h2>

            <p class="activation-text">
                Su cuenta en el aplicativo X está activada.
            </p>

            <p class="activation-text">
                Ya puede iniciar sesión.
            </p>

            <button class="btn activation-button">
                Iniciar sesión
            </button>
        </div>
    </main>

    <footer class="activation-footer">
        <div class="footer-box footer-box-image">
            <img src="~/images/footer-logos.png" alt="Logos del Estado" class="footer-logos-img" />
        </div>
    </footer>
</div>