@{
    ViewData["Title"] = "Activación de cuenta";
}

<div class="activation-page">
    <partial name="_Header" />

    <main class="activation-wrapper">
        <div class="activation-card">
            <div class="icon-circle">
                <img src="~/images/rocket-icon.svg" alt="Activación exitosa" class="rocket-icon-img" />
            </div>

            <h2 class="activation-title">¡Bienvenida, July!</h2>

            <p class="activation-text">
                Su cuenta en el aplicativo X está activada.
            </p>

            <p class="activation-text">
                Ya puede iniciar sesión.
            </p>

            <button class="btn activation-button">
                Iniciar sesión
            </button>
        </div>
    </main>

    <partial name="_Footer" />
</div>