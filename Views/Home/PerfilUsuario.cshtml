@model SistemaAccesoWeb.Models.PerfilUsuarioViewModel

@{
    ViewData["Title"] = "Perfil de usuario";
}

<div class="perfil-page">
    <aside class="perfil-sidebar">
        <div class="perfil-sidebar-top">
            <button class="perfil-menu-btn" type="button">☰</button>
        </div>

        <nav class="perfil-sidebar-nav">
            <a href="#" class="perfil-sidebar-icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
            </a>
            <a href="#" class="perfil-sidebar-icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="2" ry="2"></rect><path d="M9 22v-4h6v4"></path><path d="M8 6h.01"></path><path d="M16 6h.01"></path><path d="M12 6h.01"></path><path d="M12 10h.01"></path><path d="M12 14h.01"></path><path d="M16 10h.01"></path><path d="M16 14h.01"></path><path d="M8 10h.01"></path><path d="M8 14h.01"></path></svg>
            </a>
            <a href="#" class="perfil-sidebar-icon active">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="12" y1="18" x2="12" y2="12"></line><line x1="9" y1="15" x2="15" y2="15"></line></svg>
            </a>
            <a href="#" class="perfil-sidebar-icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
            </a>
        </nav>
    </aside>

    <div class="perfil-content-wrapper">
        <header class="perfil-header">
            <div class="perfil-header-left"></div>

            <div class="perfil-header-right">
                <span class="perfil-header-help" style="display: flex; align-items: center; cursor: pointer;">
                    <svg width="22" height="22" fill="none" stroke="#ffffff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"></circle><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
                </span>
                <span class="perfil-header-bell" style="position: relative; display: flex; align-items: center; cursor: pointer; margin-left: 12px; margin-right: 12px;">
                    <svg width="22" height="22" fill="none" stroke="#ffffff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path><path d="M13.73 21a2 2 0 0 1-3.46 0"></path></svg>
                    <span style="position: absolute; top: -2px; right: -2px; background: #0156AC; border: 2px solid #b30c0c; border-radius: 50%; width: 10px; height: 10px;"></span>
                </span>

                <div class="perfil-header-user">
                    <div class="perfil-header-avatar" style="display: flex; align-items: center;">
                        <svg width="22" height="22" fill="none" stroke="#ffffff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
                    </div>
                    <div class="perfil-header-userinfo">
                        <div class="perfil-header-name">@Model.ApellidoPaterno @Model.ApellidoMaterno, @Model.Nombres</div>
                        <div class="perfil-header-role">@Model.Rol</div>
                    </div>
                </div>
            </div>
        </header>

        <main class="perfil-main">
            <div class="perfil-breadcrumb">Gestión de usuarios</div>
            <h1 class="perfil-title">Perfil de usuario</h1>

            <section class="perfil-card">
                <div class="perfil-summary">
                    <div class="perfil-avatar-circle" style="display: flex; align-items: center; justify-content: center;">
                        <img src="~/images/icon-user.svg" style="width: 32px; height: 32px; filter: brightness(0) invert(1);" alt="Avatar" />
                    </div>

                    <div class="perfil-summary-info">
                        <div class="perfil-summary-top">
                            <h2>@Model.ApellidoPaterno @Model.ApellidoMaterno, @Model.Nombres</h2>
                            <span class="perfil-estado">@Model.Estado</span>
                        </div>

                        <p class="perfil-rol">@Model.Rol</p>
                        <p class="perfil-entidad">@Model.Entidad</p>
                    </div>
                </div>

                <div class="perfil-tabs">
                    <button type="button" class="perfil-tab active">Información básica</button>
                    <button type="button" class="perfil-tab">Responsabilidades</button>
                    <button type="button" class="perfil-tab">Historial de responsabilidades</button>
                </div>

                <div class="perfil-grid">
                    <div class="perfil-field">
                        <label>Nombres</label>
                        <div class="perfil-value">@Model.Nombres</div>
                    </div>

                    <div class="perfil-field">
                        <label>Primer Apellido</label>
                        <div class="perfil-value">@Model.ApellidoPaterno</div>
                    </div>

                    <div class="perfil-field">
                        <label>Segundo Apellido</label>
                        <div class="perfil-value">@Model.ApellidoMaterno</div>
                    </div>

                    <div class="perfil-field">
                        <label>Tipo de Documento de Identidad</label>
                        <div class="perfil-value">@Model.TipoDocumento</div>
                    </div>

                    <div class="perfil-field">
                        <label>N° de Documento de Identidad</label>
                        <div class="perfil-value">@Model.NumeroDocumento</div>
                    </div>

                    <div class="perfil-field">
                        <label>Fecha de nacimiento</label>
                        <div class="perfil-value">@(Model.FechaNacimiento?.ToString("dd / MM / yyyy") ?? "-")</div>
                    </div>

                    <div class="perfil-field">
                        <label>Nacionalidad</label>
                        <div class="perfil-value">@Model.Nacionalidad</div>
                    </div>

                    <div class="perfil-field">
                        <label>Sexo</label>
                        <div class="perfil-value">@Model.Sexo</div>
                    </div>

                    <div class="perfil-field">
                        <label>Correo electrónico principal</label>
                        <div class="perfil-value" style="justify-content: space-between;">
                            <span>@Model.CorreoPrincipal</span>
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M17 3a2.828 2.828 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5L17 3z"></path>
                            </svg>
                        </div>
                    </div>

                    <div class="perfil-field">
                        <label>Correo electrónico secundario <span class="text-muted" style="font-weight: 400; font-size: 0.9em;">(Opcional)</span></label>
                        <div class="perfil-value">@(string.IsNullOrWhiteSpace(Model.CorreoSecundario) ? "-" : Model.CorreoSecundario)</div>
                    </div>

                    <div class="perfil-field">
                        <label>Teléfono Móvil</label>
                        <div class="perfil-value" style="justify-content: space-between;">
                            <span>@Model.TelefonoMovil</span>
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M17 3a2.828 2.828 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5L17 3z"></path>
                            </svg>
                        </div>
                    </div>

                    <div class="perfil-field">
                        <label>Teléfono secundario <span>(Opcional)</span></label>
                        <div class="perfil-phone-inline">
                            <div class="perfil-phone-type">
                                @(string.IsNullOrWhiteSpace(Model.TipoTelefonoSecundario) ? "Tipo" : Model.TipoTelefonoSecundario)
                            </div>
                            <div class="perfil-phone-number">
                                @(string.IsNullOrWhiteSpace(Model.TelefonoSecundario) ? "-" : Model.TelefonoSecundario)
                            </div>
                        </div>
                    </div>

                    <div class="perfil-field">
                        <label>Tipo de Contratación</label>
                        <div class="perfil-value">@Model.TipoContratacion</div>
                    </div>

                    <div class="perfil-field">
                        <label>Fecha de contratación</label>
                        <div class="perfil-value">@(Model.FechaContratacion?.ToString("dd / MM / yyyy") ?? "-")</div>
                    </div>
                </div>
            </section>
        </main>

        <footer class="perfil-footer">
            <img src="~/images/footer-logos.png" alt="Logos del Estado" />
        </footer>

        <div id="sessionTimeoutOverlay" class="session-timeout-overlay" style="display: none;">
            <div class="session-timeout-modal">
                <div class="session-timeout-icon">
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#B7791F" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path>
                        <line x1="12" y1="9" x2="12" y2="13"></line>
                        <line x1="12" y1="17" x2="12.01" y2="17"></line>
                    </svg>
                </div>

                <div class="session-timeout-content">
                    <h3>Su sesión esta a punto de expirar</h3>
                    <p>
                        Por seguridad, su sesión expirará en
                        <span id="sessionCountdown">60</span> segundos.
                        Para continuar, seleccione "Extender sesión"
                    </p>
                </div>

                <div class="session-timeout-actions">
                    <button type="button" id="extendSessionButton" class="session-timeout-button">
                        Extender sesión
                    </button>
                </div>
            </div>
        </div>

        <script>
                    document.addEventListener("DOMContentLoaded", function () {
                        const overlay = document.getElementById("sessionTimeoutOverlay");
                        const countdown = document.getElementById("sessionCountdown");
                        const extendButton = document.getElementById("extendSessionButton");

                        if (!overlay || !countdown || !extendButton) {
                            return;
                        }

                        const tiempoTotalSegundos = 1200; // 20 minutos
                        const tiempoAvisoSegundos = 60;   // aviso 1 minuto antes

                        let segundosRestantes = tiempoTotalSegundos;
                        let modalMostrado = false;

                        const intervalo = setInterval(function () {
                            segundosRestantes--;

                            if (segundosRestantes <= tiempoAvisoSegundos && !modalMostrado) {
                                overlay.style.display = "flex";
                                modalMostrado = true;
                            }

                            if (modalMostrado) {
                                countdown.textContent = Math.max(segundosRestantes, 0);
                            }

                            if (segundosRestantes <= 0) {
                                clearInterval(intervalo);
                                window.location.href = '/Home/GestionUsuarios?sesionExpirada=1';
                            }
                        }, 1000);

                        extendButton.addEventListener("click", function () {
                            window.location.reload();
                        });
                    });
        </script>

    </div>
</div>