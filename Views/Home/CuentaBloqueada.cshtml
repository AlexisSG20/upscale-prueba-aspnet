@{
    ViewData["Title"] = "Cuenta bloqueada";
}

<div class="gestion-page">
    <partial name="_Header" />

    <main class="gestion-main cuenta-bloqueada-main">
        <div class="gestion-background">
            <div class="gestion-bg-art"></div>

            <div class="blocked-card">
                <svg viewBox="0 0 100 100" class="blocked-icon" xmlns="http://www.w3.org/2000/svg" aria-label="Cuenta bloqueada" style="width: 100px; height: 100px;">
                    <path d="M50 15 C75 10 90 30 85 55 C80 85 60 90 40 85 C15 80 10 55 15 35 C20 15 35 18 50 15 Z" fill="#eff4fd" />
                    <path d="M25 25 L29 25 M27 23 L27 27" stroke="#0056b3" stroke-width="2" stroke-linecap="round" />
                    <path d="M80 30 L84 30 M82 28 L82 32" stroke="#0056b3" stroke-width="2" stroke-linecap="round" />

                    <circle cx="50" cy="45" r="14" fill="white" stroke="#0056b3" stroke-width="3" />
                    <path d="M30 80 C30 63 40 60 50 60 C60 60 70 63 70 80 Z" fill="white" stroke="#0056b3" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />

                    <path d="M32 45 C32 25 68 25 68 45" fill="none" stroke="#0056b3" stroke-width="3" stroke-linecap="round" />
                    <rect x="28" y="40" width="8" height="15" rx="4" fill="#eff4fd" stroke="#0056b3" stroke-width="3" />
                    <rect x="64" y="40" width="8" height="15" rx="4" fill="#eff4fd" stroke="#0056b3" stroke-width="3" />

                    <!-- Simbolo de bloqueo o exclamacion pequeña como detalle si quisieras, aquí un microfono como en soporte -->
                    <path d="M68 50 C75 55 60 60 55 60" fill="none" stroke="#0056b3" stroke-width="3" stroke-linecap="round" />
                </svg>

                <h2 class="blocked-title">Cuenta bloqueada<br />temporalmente</h2>

                <p class="blocked-text">
                    Has excedido el número máximo de intentos fallidos (5). Por seguridad, tu cuenta ha sido
                    bloqueada durante 15 minutos. Intenta nuevamente más tarde.
                </p>
            </div>
        </div>
    </main>

    <partial name="_Footer" />
</div>